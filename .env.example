# Copy to .env and fill in. Used by docker-compose.yml + deploy/Caddyfile.
# NEVER commit the real .env (it is gitignored).

# Public hostname users visit. For a real deployment this must be a domain that
# resolves to this server so Caddy can obtain a Let's Encrypt certificate.
# Use "localhost" for a local trial (Caddy issues an internal self-signed cert).
PERDURA_DOMAIN=perdura.example.com

# Email for Let's Encrypt certificate issuance/expiry notices (real domains).
# Leave blank for a localhost trial.
PERDURA_TLS_EMAIL=admin@example.com

# Reverse-proxy basic-auth credential (the app itself has no login).
# Generate the bcrypt hash:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'your-strong-password'
# Paste the hash below. Escape any '$' as '$$' when used inside docker-compose.
BASICAUTH_USER=admin
BASICAUTH_HASH=

# Uvicorn worker processes. Scale toward the number of CPU cores available.
WEB_CONCURRENCY=4

# Optional browser origins permitted to call the API cross-origin. The normal
# same-origin UI does not require this. Separate multiple origins with commas.
PERDURA_CORS_ORIGINS=

# Version stamped into the image (shown in the UI footer and /api/v1/version).
# Set to the release you're deploying, e.g. 0.3.2. Defaults to "dev".
APP_VERSION=dev
