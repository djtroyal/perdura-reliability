# Perdura reverse proxy — TLS termination + authentication in front of the
# open app. Values come from the environment (see .env.example / compose).
#
# Perdura has NO authentication of its own; this proxy is the ONLY thing
# standing between the public and full, unauthenticated use of every (CPU-heavy)
# compute endpoint. Keep the app container unpublished and always front it here.
{
	# ACME contact for Let's Encrypt. Leave blank for a local/internal trial
	# (PERDURA_DOMAIN=localhost), where Caddy issues its own internal cert.
	email {$PERDURA_TLS_EMAIL}
}

# The public site. With a real domain that resolves to this host, Caddy obtains
# and renews a Let's Encrypt certificate automatically.
{$PERDURA_DOMAIN} {
	# --- Authentication (basic-auth placeholder) --------------------------
	# Generate a bcrypt hash for your password:
	#   docker run --rm caddy:2 caddy hash-password --plaintext 'your-strong-password'
	# then set BASICAUTH_USER and BASICAUTH_HASH in .env.
	# (For a quick no-auth LOCAL trial only, comment out this block.)
	basic_auth {
		{$BASICAUTH_USER} {$BASICAUTH_HASH}
	}

	# One origin for both the SPA and /api — the app serves the built UI and
	# the API together, so no path rules are needed. flush_interval -1 streams
	# responses immediately so the NDJSON fit-progress stream
	# (/api/life-data/fit/stream) reaches the browser line by line.
	reverse_proxy app:8000 {
		flush_interval -1
	}

	# Browser-facing defense in depth for the reference deployment. HSTS is
	# deliberately applied at the TLS terminator rather than the unauthenticated
	# application container. The CSP permits Perdura's locally generated images,
	# Plotly/Web Worker blobs, and KaTeX's inline style attributes; it does not
	# permit remote scripts, frames, plugins, or form posts to another origin.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self'; connect-src 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
		-Server
	}

	# Bound all uploads at the public edge. Organizations may choose a lower
	# value after qualifying their largest approved project and image exports.
	request_body {
		max_size 100MB
	}

	encode zstd gzip
}

# --- SSO alternative --------------------------------------------------------
# To use single sign-on instead of basic-auth, run an oauth2-proxy sidecar and
# replace the basic_auth block above with a forward_auth block:
#
# {$PERDURA_DOMAIN} {
# 	forward_auth oauth2-proxy:4180 {
# 		uri /oauth2/auth
# 		copy_headers X-Auth-Request-User X-Auth-Request-Email
# 	}
# 	handle /oauth2/* {
# 		reverse_proxy oauth2-proxy:4180
# 	}
# 	reverse_proxy app:8000
# }
